# Discord bot token (dedicated bot)
DISCORD_BOT_TOKEN=<YOUR_DISCORD_BOT_TOKEN>

# comma-separated allowed user IDs
ALLOWED_USER_IDS=<YOUR_DISCORD_USER_ID>

# comma-separated allowed channel IDs
ALLOWED_CHANNEL_IDS=<YOUR_DISCORD_CHANNEL_ID>

# command prefix
COMMAND_PREFIX=!oc

# stop confirm timeout seconds
STOP_CONFIRM_SECONDS=30
