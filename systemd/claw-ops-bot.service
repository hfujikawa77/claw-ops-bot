[Unit]
Description=OpenClaw Power Discord Bot (LLM-free)
After=network-online.target

# NOTE:
# Prefer scripts/install-user-service.sh for installation.
# This file is kept as a reference template only.

[Service]
Type=simple
Environment=BOT_HOME=%h/claw-ops-bot
Environment=ENV_FILE=%h/.config/claw-ops-bot.env
ExecStart=%h/claw-ops-bot/scripts/run.sh
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
